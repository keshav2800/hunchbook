# Telegram bot token from @BotFather (/newbot in Telegram)
TELEGRAM_BOT_TOKEN=

# Master key for AES-GCM encryption of user secret keys.
# Generate with: openssl rand -base64 32
# IF YOU LOSE THIS, ALL USER WALLETS BECOME UNRECOVERABLE from the DB.
HUNCHBOOK_BOT_MASTER_KEY=

# Optional: override the DB file path
# BOT_DB_PATH=data/hunchbook.db
