// Hunchbook off-chain data (Postgres / Neon).
// Identity in `profiles`. The leaderboard tables (`bet_txs`, `cashout_txs`,
// `leaderboard_sync`) are a cache of router txs scanned by /api/leaderboard/sync,
// so the leaderboard can aggregate over full history without re-scanning chain.
// Use Neon's POOLED connection string in DATABASE_URL for serverless (…-pooler.…).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Off-chain user profile. Username uniqueness is enforced case-insensitively in
/// code (see upsertProfile); email is write-once (set from Google sign-in).
model Profile {
  address   String   @id
  username  String
  email     String   @default("")
  bio       String   @default("")
  views     Int      @default(0) // public-profile view counter (bumped on public GET)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

/// One row per router::place_bet success tx. Populated by /api/leaderboard/sync
/// walking the chain newest-first; `digest` is the on-chain idempotency key.
model BetTx {
  digest      String   @id
  sender      String
  oracleId    String
  expiry      BigInt
  strikeUsd   Float
  direction   String   // 'UP' | 'DOWN'
  stakeUsd    Float
  units       Float
  timestampMs BigInt
  createdAt   DateTime @default(now())

  @@index([sender])
  @@index([timestampMs])
  @@map("bet_txs")
}

/// One row per router::cashout success tx. Mirrors BetTx — joined to bets in
/// the leaderboard aggregator by (sender, oracleId, expiry, strike, direction).
model CashoutTx {
  digest      String   @id
  sender      String
  oracleId    String
  expiry      BigInt
  strikeUsd   Float
  direction   String
  receivedUsd Float
  timestampMs BigInt
  createdAt   DateTime @default(now())

  @@index([sender])
  @@index([timestampMs])
  @@map("cashout_txs")
}

/// Singleton (id='leaderboard') tracking the newest tx digest the sync job has
/// already absorbed per router function — lets each sync resume incrementally
/// instead of re-scanning the whole chain.
model LeaderboardSync {
  id              String   @id
  lastBetDigest   String?
  lastCashoutDigest String?
  lastRunAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("leaderboard_sync")
}
